# Copy this file to `.env` and fill in the six values from your Firebase project
# (Project Settings → General → Your apps → web app config). Restart the dev server
# afterwards.
#
# Leave them blank — or skip the .env entirely — and the app runs in demo mode with
# seeded local data instead. Nothing else changes.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
