# Copy this file to `.env` and fill in the two values from your Supabase project
# (Project Settings → API). Restart the dev server afterwards.
#
# Leave them blank — or skip the .env entirely — and the app runs in demo mode with
# seeded local data instead. Nothing else changes.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
